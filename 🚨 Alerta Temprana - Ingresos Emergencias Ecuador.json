        "jsCode": "const item = $input.first().json;\nlet analisis = {};\n\ntry {\n  const rawContent = item.choices?.[0]?.message?.content || '{}';\n  const cleaned = rawContent.replace(/```json|```/g, '').trim();\n  analisis = JSON.parse(cleaned);\n} catch(e) {\n  analisis = {\n    cubierto: false,\n    cobertura_estimada: 0,\n    requiere_autorizacion: true,\n    nivel_urgencia: 'ALTO',\n    observaciones: 'Error al analizar respuesta IA: ' + e.message,\n    acciones_inmediatas: ['Revisar manualmente']\n  };\n}\n\nconst timestamp = new Date().toISOString();\nconst id_caso = 'CASO-' + Date.now();\n\nreturn [{ json: { ...item, analisis, timestamp, id_caso } }];"
