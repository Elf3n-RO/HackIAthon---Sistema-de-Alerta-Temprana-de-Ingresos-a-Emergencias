        "jsCode": "const items = $input.all();\nconst polizaRaw = items[0]?.json || null;\nlet poliza = null;\n\nif (polizaRaw) {\n  try {\n    poliza = polizaRaw.data ? JSON.parse(polizaRaw.data) : polizaRaw;\n  } catch(e) {\n    poliza = polizaRaw;\n  }\n}\n\nreturn [{ json: { ...polizaRaw, poliza, tiene_poliza: poliza !== null } }];"
